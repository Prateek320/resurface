{
  "manifest_version": 3,
  "name": "Resurface — Save Opportunity",
  "version": "1.0.0",
  "description": "Save LinkedIn posts, job listings, and selected text to Resurface",
  "permissions": ["contextMenus", "activeTab", "storage"],
  "host_permissions": ["http://localhost:3000/*", "https://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Resurface"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
